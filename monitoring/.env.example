# Copialo a monitoring/.env (gitignored) y completa los valores.
# Docker Compose lo lee automaticamente al levantar el stack local
# (docker compose -f monitoring/docker-compose.yml up).
#
# En el deploy AWS estas variables NO se usan: alli las credenciales vienen
# de los secrets de GitHub Actions via variables de Terraform.

# Grafana. El dashboard es publico de solo-lectura (anonimo Viewer); estas
# credenciales son la cuenta admin para editar. Cambia la password.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=cambia-esta-password

# Proxy de clima
REDIS_TTL=300
OPEN_METEO_URL=https://api.open-meteo.com
